FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me

# Direct connection
MYSQL_HOST=redmine-db.example.internal
MYSQL_PORT=3306
MYSQL_DATABASE=redmine
MYSQL_USER=redmine_user
MYSQL_PASSWORD=replace_with_real_password

MYSQL_QUALITY_HOST=quality-db.example.internal
MYSQL_QUALITY_PORT=3306
MYSQL_QUALITY_DATABASE=redmine
MYSQL_QUALITY_USER=quality_user
MYSQL_QUALITY_PASSWORD=replace_with_real_password

# Oracle (optional)
ORACLE_HOST=oracle-db.example.internal
ORACLE_PORT=11521
ORACLE_SERVICE_NAME=ENISK.TEZTOUR.COM
ORACLE_USER=oracle_user
ORACLE_PASSWORD=replace_with_real_password
ORACLE_TCP_TIMEOUT=3
ORACLE_LOGIN_CHECK=off

REDMINE_URL=https://redmine.example.internal
REDMINE_API_KEY=change-me
REDMINE_LOGIN_ADMIN=redmine_admin
REDMINE_PASSWORD_ADMIN=replace_with_real_password
REDMINE_QUALITY_URL=https://redmine-quality.example.internal
REDMINE_QUALITY_API_KEY=change-me
REDMINE_QUALITY_LOGIN_ADMIN=quality_admin
REDMINE_QUALITY_PASSWORD_ADMIN=replace_with_real_password
REDMINE_QUALITY_ANONYMOUS_USER_ID=4
REDMINE_ANONYMOUS_USER_ID=4

# Cisco Finesse
FINESSE_BASE_URL=https://uccx-pub.teztour.com:8445
FINESSE_VERIFY_SSL=false
# FINESSE_CA_BUNDLE=/path/to/company-ca-bundle.pem
# FINESSE_MONITOR_USERNAME=supervisor_login
# FINESSE_MONITOR_PASSWORD=supervisor_password

SESSION_TYPE=filesystem
SESSION_FILE_DIR=/tmp/flask_sessions
PERMANENT_SESSION_LIFETIME=86400
DB_PATH=blog/db/blog.db

# Logging configuration - DEVELOPMENT
LOG_LEVEL=DEBUG
LOG_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
STAT_LOG_MAX_BYTES=5242880
STAT_LOG_BACKUP_COUNT=3
ERROR_LOG_MAX_BYTES=10485760
ERROR_LOG_BACKUP_COUNT=5
